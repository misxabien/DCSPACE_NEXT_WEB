MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=dcspace_user
JWT_SECRET=change-this-super-secret-key
JWT_EXPIRES_IN=7d

# Use in-memory verification codes when MongoDB is unavailable (local dev only)
VERIFICATION_USE_MEMORY=false

# Required: SMTP so verification codes are emailed (not shown in the app)
# Gmail / Google Workspace example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your-account@sdca.edu.ph
#   SMTP_PASS=your-app-password
#   SMTP_FROM=DC Space <your-account@sdca.edu.ph>
# Required for registration verification emails (Gmail / Google Workspace example):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@sdca.edu.ph
SMTP_PASS=your-gmail-app-password
SMTP_FROM=DC Space <your-account@sdca.edu.ph>

# If SMTP is not set, dev mode logs the code in the backend-user terminal:
# VERIFICATION_LOG_CODE=true
