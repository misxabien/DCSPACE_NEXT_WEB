# Copy to .env.local at the repo root (used by Next.js on port 3000)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=dcspace_user
JWT_SECRET=change-this-super-secret-key
JWT_EXPIRES_IN=7d
NEXTAUTH_SECRET=change-this-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Registration verification email (optional in dev — code prints in terminal if SMTP empty)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@sdca.edu.ph
SMTP_PASS=your-gmail-app-password
SMTP_FROM=DC Space <your-account@sdca.edu.ph>
# false = store codes in MongoDB (required for registration; survives dev reload)
VERIFICATION_USE_MEMORY=false
VERIFICATION_LOG_CODE=false

# Atlas example (encode special characters in the password):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB_NAME=dcspace_user

# Also copy the same MONGODB_* and JWT_* values into backend-user/.env
