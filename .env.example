# Copy to .env.local at the repo root.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=dcspace
JWT_SECRET=change-this-super-secret-key
JWT_EXPIRES_IN=7d

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Development admin login (auto-seeded on sign-in; also: npm run seed:admin)
DEV_ADMIN_EMAIL=admin@sdca.edu.ph
DEV_ADMIN_PASSWORD=Admin@123
DEV_ADMIN_NAME=DC Space Admin

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_GOOGLE_DOMAIN=sdca.edu.ph

# Admin dashboard smart recommendations.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Registration verification email.
# Optional in dev if VERIFICATION_LOG_CODE=true.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@sdca.edu.ph
SMTP_PASS=your-gmail-app-password
SMTP_FROM=DC Space <your-account@sdca.edu.ph>
VERIFICATION_USE_MEMORY=false
VERIFICATION_LOG_CODE=false

# Atlas example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB_NAME=dcspace
